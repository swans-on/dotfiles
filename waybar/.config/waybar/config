        "states": {
            "warning": 70,
            "critical": 90
        }
    },
    "memory": {
        "interval": 30,
        "format": "{}% ’āē",
        "max-length": 10,
        "states": {
            "warning": 70,
            "critical": 90
        }
    },
    "disk": {
        "interval": 30,
        "format": "¾░ŗŖ {percentage_used}%",
        "path": "/",
